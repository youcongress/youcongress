<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%= if assigns[:page_title] do %>
      <%= if assigns[:skip_page_suffix] do %>
        <title>{assigns[:page_title]}</title>
        <meta content={assigns[:page_title]} property="og:title" />
      <% else %>
        <.live_title suffix=" / YouCongress">
          {assigns[:page_title]}
        </.live_title>
        <meta content={"#{assigns[:page_title]} / YouCongress"} property="og:title" />
      <% end %>
    <% else %>
      <title>YouCongress</title>
    <% end %>
    <%= if assigns[:page_description] do %>
      <meta name="description" content={assigns[:page_description]} />
      <meta content={assigns[:page_description]} property="og:description" />
      <meta name="twitter:description" content={assigns[:page_description]} />
    <% end %>
    <%= if assigns[:canonical_url] do %>
      <link rel="canonical" href={assigns[:canonical_url]} />
      <meta property="og:url" content={assigns[:canonical_url]} />
    <% end %>
    <meta property="og:type" content={assigns[:og_type] || "website"} />
    <meta property="og:site_name" content="YouCongress" />
    <meta property="og:image" content={assigns[:page_image] || url(~p"/images/og-default.png")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={assigns[:page_title] || "YouCongress"} />
    <%= if assigns[:noindex] do %>
      <meta name="robots" content="noindex" />
    <% end %>

    <%!-- Discovery hints for AI assistants/agents: YouCongress exposes an MCP server. --%>
    <link rel="llms" type="text/markdown" href={~p"/llms.txt"} title="YouCongress for AI agents" />
    <meta name="mcp-server" content={url(~p"/mcp")} />

    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static src={~p"/assets/app.js"}>
    </script>
    <%= if Application.get_env(:you_congress, :env) == :prod do %>
      <script defer data-domain="youcongress.org" src="https://plausible.io/js/script.js">
      </script>
    <% end %>
  </head>
  <body class="bg-white antialiased">
    {@inner_content}
  </body>
</html>
